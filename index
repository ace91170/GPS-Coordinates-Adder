<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8">
<title>Live GPS Logger - Double Tap</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
  html, body { margin:0; padding:0; height: 100%; overflow: hidden; font-family: sans-serif; }
  #map { width:100%; height:100vh; z-index: 1; }
  
  /* Indikator Status */
  .status-bar {
    position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
    z-index: 2000; background: rgba(0,0,0,0.7); color: white;
    padding: 8px 15px; border-radius: 20px; font-size: 12px; pointer-events: none;
  }

  /* Panel Kontrol */
  .controls {
    position: absolute; bottom: 30px; right: 10px; z-index: 2000;
    display: flex; flex-direction: column; gap: 10px;
  }
  .btn {
    background: #fff; border: none; padding: 15px; border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3); font-weight: bold; cursor: pointer;
  }
  .btn-download { background: #28a745; color: white; }
  .btn-clear { background: #dc3545; color: white; font-size: 10px; }

  /* Animasi Notifikasi */
  #toast {
    position: absolute; top: 20%; left: 50%; transform: translate(-50%, -50%);
    background: #007bff; color: white; padding: 15px 25px; border-radius: 10px;
    z-index: 3000; display: none; font-weight: bold; box-shadow: 0 5px 15px rgba(0,0,0,0.3);
  }
</style>
</head>
<body>

<div id="toast">📍 KOORDINAT TERSIMPAN!</div>
<div class="status-bar" id="stat">Mencari GPS...</div>

<div id="map"></div>

<div class="controls">
  <button class="btn btn-download" onclick="exportData()">💾 Ekspor .TXT (Append)</button>
  <button class="btn btn-clear" onclick="clearData()">⚠️ Hapus Memori</button>
</div>

<script>
let savedCoords = JSON.parse(localStorage.getItem('myGpsLog')) || [];
let currentPos = null;

// 1. Inisialisasi Peta
const map = L.map('map').setView([-2.0, 113.0], 5);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

// Marker Posisi Live
const marker = L.circleMarker([0,0], {radius: 8, color: 'white', fillColor: '#007bff', fillOpacity: 1, weight: 2}).addTo(map);

// 2. Fungsi Tracking GPS
navigator.geolocation.watchPosition(
  (pos) => {
    currentPos = [pos.coords.latitude, pos.coords.longitude];
    const latlng = new L.LatLng(currentPos[0], currentPos[1]);
    marker.setLatLng(latlng);
    map.setView(latlng, 16);
    document.getElementById('stat').innerText = `LIVE: ${currentPos[0].toFixed(5)}, ${currentPos[1].toFixed(5)} | Terlog: ${savedCoords.length}`;
  },
  (err) => console.error(err),
  { enableHighAccuracy: true }
);

// 3. Logika Double Tap untuk Simpan (Append)
let lastTap = 0;
document.addEventListener('touchend', function (e) {
  let currentTime = new Date().getTime();
  let tapLength = currentTime - lastTap;
  if (tapLength < 300 && tapLength > 0) {
    saveCoordinate();
    e.preventDefault();
  }
  lastTap = currentTime;
});

function saveCoordinate() {
  if (!currentPos) return alert("GPS belum siap!");
  
  // Format data: [lat, lng]
  const entry = `[${currentPos[0]}, ${currentPos[1]}]`;
  savedCoords.push(entry);
  
  // Simpan ke LocalStorage (Metode Append)
  localStorage.setItem('myGpsLog', JSON.stringify(savedCoords));
  
  // Tampilkan Notifikasi
  const toast = document.getElementById('toast');
  toast.style.display = 'block';
  setTimeout(() => { toast.style.display = 'none'; }, 1000);
  
  document.getElementById('stat').innerText = `LIVE: ${currentPos[0].toFixed(5)}, ${currentPos[1].toFixed(5)} | Terlog: ${savedCoords.length}`;
}

// 4. Ekspor ke File TXT
function exportData() {
  if (savedCoords.length === 0) return alert("Belum ada data yang tersimpan.");
  
  const blobData = savedCoords.join(",\n");
  const blob = new Blob([blobData], { type: 'text/plain' });
  const url = window.URL.createObjectURL(blob);
  const a = document.createElement('a');
  
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  a.href = url;
  a.download = `GPS_Log_${timestamp}.txt`;
  document.body.appendChild(a);
  a.click();
  window.URL.revokeObjectURL(url);
  document.body.removeChild(a);
}

// 5. Reset Memori
function clearData() {
  if (confirm("Hapus semua data yang sudah dicatat?")) {
    savedCoords = [];
    localStorage.removeItem('myGpsLog');
    location.reload();
  }
}
</script>
</body>
</html>

